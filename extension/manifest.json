{
  "manifest_version": 3,
  "name": "TabScroller",
  "version": "1.0.0",
  "description": "Switch tabs by holding right-click and scrolling the mouse wheel. Works on all tabs including pinned. Keyboard shortcuts: Ctrl+Shift+Right/Left.",
  "permissions": [
    "tabs",
    "scripting",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start",
      "all_frames": true,
      "match_about_blank": true,
      "match_origin_as_fallback": true
    }
  ],
  "options_page": "options.html",
  "action": {
    "default_title": "TabScroller Settings"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "commands": {
    "next-tab": {
      "suggested_key": {
        "default": "Ctrl+Shift+Right"
      },
      "description": "Switch to next tab"
    },
    "prev-tab": {
      "suggested_key": {
        "default": "Ctrl+Shift+Left"
      },
      "description": "Switch to previous tab"
    }
  }
}